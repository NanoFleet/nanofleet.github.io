---
/**
 * DocsLayout
 * Layout for documentation pages.
 * Persistent left sidebar with navigation + main prose content area.
 */
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;

const sidebarSections = [
  {
    label: 'Getting Started',
    items: [
      { label: 'Installation (UI)', href: '/docs/getting-started/ui' },
      { label: 'Installation (Standalone)', href: '/docs/getting-started/standalone' },
    ],
  },
  {
    label: 'Agents',
    items: [
      { label: 'Overview', href: '/docs/agents/overview' },
      { label: 'Agent Packs', href: '/docs/agents/packs' },
      { label: 'Scheduling', href: '/docs/agents/scheduling' },
    ],
  },
  {
    label: 'Plugins',
    items: [
      { label: 'Overview', href: '/docs/plugins/overview' },
      { label: 'Installing a plugin', href: '/docs/plugins/installing' },
      { label: 'Building a plugin', href: '/docs/plugins/building' },
      { label: 'nanofleet-tasks', href: '/docs/plugins/nanofleet-tasks' },
      { label: 'nanofleet-vault', href: '/docs/plugins/nanofleet-vault' },
    ],
  },
  {
    label: 'Channels',
    items: [
      { label: 'Overview', href: '/docs/channels/overview' },
      { label: 'Telegram', href: '/docs/channels/telegram' },
    ],
  },
  {
    label: 'NanoFleet UI',
    items: [
      { label: 'Overview', href: '/docs/ui/overview' },
      { label: 'Managing agents', href: '/docs/ui/agents' },
      { label: 'Settings', href: '/docs/ui/settings' },
    ],
  },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '');
---

<BaseLayout title={title ? `${title} — NanoFleet Docs` : 'NanoFleet Docs'} description={description}>
  <Header
    slot="header"
    showThemeToggle={false}
    actions={[
      {
        icon: 'github',
        href: 'https://github.com/NanoFleet/nanofleet',
        label: 'GitHub',
        iconOnly: true,
        target: '_blank',
      },
    ]}
  />

  <div class="flex min-h-screen pt-16">
    <!-- Sidebar -->
    <aside
      class="docs-sidebar hidden lg:flex flex-col w-64 xl:w-72 shrink-0 border-r border-border bg-background fixed top-16 bottom-0 left-0 overflow-y-auto z-10"
      id="docs-sidebar"
    >
      <nav class="px-4 py-6 space-y-6" aria-label="Documentation navigation">
        {sidebarSections.map((section) => (
          <div>
            <p class="px-2 mb-1 text-xs font-semibold uppercase tracking-wider text-foreground-subtle select-none">
              {section.label}
            </p>
            <ul class="space-y-0.5">
              {section.items.map((item) => {
                const isActive = currentPath === item.href || currentPath === item.href.replace(/\/$/, '');
                return (
                  <li>
                    <a
                      href={item.href}
                      class:list={[
                        'block rounded-md px-2 py-1.5 text-sm transition-colors',
                        isActive
                          ? 'bg-secondary text-foreground font-medium'
                          : 'text-foreground-muted hover:text-foreground hover:bg-secondary/60',
                      ]}
                      aria-current={isActive ? 'page' : undefined}
                    >
                      {item.label}
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        ))}
      </nav>
    </aside>

    <!-- Mobile sidebar toggle -->
    <button
      type="button"
      id="docs-sidebar-toggle"
      class="lg:hidden fixed bottom-6 right-6 z-50 flex items-center justify-center w-12 h-12 rounded-full bg-primary text-primary-foreground shadow-lg"
      aria-label="Toggle navigation"
      aria-expanded="false"
      aria-controls="docs-sidebar-mobile"
    >
      <span class="menu-icon"><Icon name="menu" size="md" /></span>
      <span class="close-icon hidden"><Icon name="x" size="md" /></span>
    </button>

    <!-- Mobile sidebar drawer -->
    <div
      id="docs-sidebar-mobile"
      class="lg:hidden fixed inset-0 z-40 hidden"
      role="dialog"
      aria-modal="true"
      aria-label="Documentation navigation"
    >
      <div class="absolute inset-0 bg-black/50" id="docs-sidebar-backdrop"></div>
      <aside class="absolute left-0 top-0 bottom-0 w-72 bg-background border-r border-border overflow-y-auto">
        <div class="flex items-center justify-between px-4 py-4 border-b border-border">
          <span class="text-sm font-semibold text-foreground">Documentation</span>
          <button type="button" id="docs-sidebar-close" class="text-foreground-muted hover:text-foreground" aria-label="Close navigation">
            <Icon name="x" size="md" />
          </button>
        </div>
        <nav class="px-4 py-6 space-y-6">
          {sidebarSections.map((section) => (
            <div>
              <p class="px-2 mb-1 text-xs font-semibold uppercase tracking-wider text-foreground-subtle select-none">
                {section.label}
              </p>
              <ul class="space-y-0.5">
                {section.items.map((item) => {
                  const isActive = currentPath === item.href || currentPath === item.href.replace(/\/$/, '');
                  return (
                    <li>
                      <a
                        href={item.href}
                        class:list={[
                          'block rounded-md px-2 py-1.5 text-sm transition-colors',
                          isActive
                            ? 'bg-secondary text-foreground font-medium'
                            : 'text-foreground-muted hover:text-foreground hover:bg-secondary/60',
                        ]}
                        aria-current={isActive ? 'page' : undefined}
                      >
                        {item.label}
                      </a>
                    </li>
                  );
                })}
              </ul>
            </div>
          ))}
        </nav>
      </aside>
    </div>

    <!-- Main content -->
    <div class="flex-1 min-w-0 lg:pl-64 xl:pl-72">
      <div class="mx-auto max-w-3xl px-6 py-10 lg:px-10">
        <article class="docs-prose">
          <slot />
        </article>
      </div>
    </div>
  </div>
</BaseLayout>

<style is:global>
  /* Docs prose typography */
  .docs-prose {
    color: var(--color-foreground);
    font-size: 0.9375rem;
    line-height: 1.75;
  }

  .docs-prose h1 {
    font-size: 1.875rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-foreground);
    margin-bottom: 0.5rem;
    margin-top: 0;
    line-height: 1.2;
  }

  .docs-prose h2 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .docs-prose h3 {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
  }

  .docs-prose p {
    margin-bottom: 1rem;
    color: var(--color-foreground-secondary);
  }

  .docs-prose a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .docs-prose a:hover {
    opacity: 0.8;
  }

  .docs-prose ul,
  .docs-prose ol {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .docs-prose ul { list-style-type: disc; }
  .docs-prose ol { list-style-type: decimal; }
  .docs-prose li {
    margin-bottom: 0.25rem;
    color: var(--color-foreground-secondary);
  }

  .docs-prose code:not(pre code) {
    font-family: var(--font-mono, 'JetBrains Mono Variable', monospace);
    font-size: 0.8125rem;
    background: var(--color-secondary);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.1em 0.4em;
    color: var(--color-foreground);
  }

  .docs-prose pre {
    background: #0d1117;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.25rem;
    font-size: 0.8125rem;
    line-height: 1.7;
  }

  .docs-prose pre code {
    background: transparent;
    border: none;
    padding: 0;
    font-size: inherit;
    color: inherit;
  }

  /* Tables */
  .docs-prose table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.25rem;
    font-size: 0.875rem;
  }
  .docs-prose thead th {
    text-align: left;
    padding: 0.5rem 0.75rem;
    background: var(--color-secondary);
    border: 1px solid var(--color-border);
    font-weight: 600;
    color: var(--color-foreground);
  }
  .docs-prose tbody td {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border);
    color: var(--color-foreground-secondary);
    vertical-align: top;
  }
  .docs-prose tbody tr:nth-child(even) td {
    background: color-mix(in oklch, var(--color-secondary) 40%, transparent);
  }

  /* Blockquotes */
  .docs-prose blockquote {
    border-left: 3px solid var(--color-border-strong);
    padding: 0.5rem 1rem;
    margin: 1rem 0;
    background: var(--color-secondary);
    border-radius: 0 6px 6px 0;
  }
  .docs-prose blockquote p {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-foreground-muted);
  }

  /* GitHub-style alerts (remark-github-alerts) */
  .markdown-alert {
    border-left: 3px solid var(--color-border-strong);
    padding: 0.5rem 1rem;
    margin: 1rem 0;
    border-radius: 0 6px 6px 0;
  }
  .markdown-alert.markdown-alert-note { border-color: #58a6ff; background: rgba(88, 166, 255, 0.08); }
  .markdown-alert.markdown-alert-tip { border-color: #3fb950; background: rgba(63, 185, 80, 0.08); }
  .markdown-alert.markdown-alert-warning { border-color: #d29922; background: rgba(210, 153, 34, 0.08); }
  .markdown-alert.markdown-alert-important { border-color: #a371f7; background: rgba(163, 113, 247, 0.08); }
  .markdown-alert.markdown-alert-caution { border-color: #f85149; background: rgba(248, 81, 73, 0.08); }
  .markdown-alert-title { font-size: 0.8125rem; font-weight: 600; margin-bottom: 0.25rem; }
  .markdown-alert p { margin: 0; font-size: 0.875rem; }

  /* Horizontal rule */
  .docs-prose hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }
</style>

<script>
  function initDocsSidebar() {
    const toggle = document.getElementById('docs-sidebar-toggle');
    const drawer = document.getElementById('docs-sidebar-mobile');
    const backdrop = document.getElementById('docs-sidebar-backdrop');
    const closeBtn = document.getElementById('docs-sidebar-close');

    if (!toggle || !drawer) return;
    if (toggle.dataset.sidebarInit) return;
    toggle.dataset.sidebarInit = 'true';

    const menuIcon = toggle.querySelector('.menu-icon');
    const closeIcon = toggle.querySelector('.close-icon');

    function open() {
      drawer!.classList.remove('hidden');
      toggle!.setAttribute('aria-expanded', 'true');
      menuIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      drawer!.classList.add('hidden');
      toggle!.setAttribute('aria-expanded', 'false');
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      document.body.style.overflow = '';
    }

    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      if (isOpen) close(); else open();
    });

    backdrop?.addEventListener('click', close);
    closeBtn?.addEventListener('click', close);
    drawer.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });
  }

  initDocsSidebar();
  document.addEventListener('astro:page-load', initDocsSidebar);
  document.addEventListener('astro:after-swap', initDocsSidebar);
</script>
